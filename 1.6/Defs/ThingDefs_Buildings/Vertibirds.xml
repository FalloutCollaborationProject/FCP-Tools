        <statBases>
            <MaxHitPoints>1000</MaxHitPoints>
            <Flammability>0.5</Flammability>
            <WorkToBuild>55000</WorkToBuild>
            <Mass>150</Mass>
            <Comfort>0.65</Comfort>
        </statBases>
        <tickerType>Normal</tickerType>
        <designationCategory>Odyssey</designationCategory>
        <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
        <costList>
            <Steel>500</Steel>
            <ComponentIndustrial>15</ComponentIndustrial>
            <FCP_Vertibird_Engine>1</FCP_Vertibird_Engine>
        </costList>
        <canOverlapZones>true</canOverlapZones>
        <killedLeavings>
            <Steel>100</Steel>
            <ChunkSlagSteel>4</ChunkSlagSteel>
            <ComponentIndustrial>7</ComponentIndustrial>
        </killedLeavings>
        <rotatable>false</rotatable>
        <hasInteractionCell>true</hasInteractionCell>
        <interactionCellOffset>(5, 0, 0)</interactionCellOffset>
        <selectable>true</selectable>
        <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
        <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
        <preventSkyfallersLandingOn>true</preventSkyfallersLandingOn>
        <drawerType>RealtimeOnly</drawerType>
        <repairEffect>ConstructMetal</repairEffect>
        <forceDebugSpawnable>true</forceDebugSpawnable>
        <building>
            <claimable>false</claimable>
            <destroySound>BuildingDestroyed_Metal_Big</destroySound>
            <paintable>true</paintable>
            <isInert>true</isInert>
            <forcedCostLeavings>
                <li>FCP_Vertibird_Engine</li>
            </forcedCostLeavings>
        </building>
        <inspectorTabs>
            <li>ITab_ContentsTransporter</li>
        </inspectorTabs>
        <researchPrerequisites>
            <li>FCP_Vertibird_Construction</li>
        </researchPrerequisites>
        <comps>
            <li Class="CompProperties_Transporter">
                <massCapacity>1000</massCapacity>
                <max1PerGroup>true</max1PerGroup>
                <canChangeAssignedThingsAfterStarting>true</canChangeAssignedThingsAfterStarting>
                <pawnLoadedSound>Shuttle_PawnLoaded</pawnLoadedSound>
                <pawnExitSound>Shuttle_PawnExit</pawnExitSound>
                <showMassInInspectString>true</showMassInInspectString>
            </li>
            <li Class="CompProperties_Refuelable">
                <fuelCapacity>500</fuelCapacity>
                <targetFuelLevelConfigurable>true</targetFuelLevelConfigurable>
                <initialConfigurableTargetFuelLevel>500</initialConfigurableTargetFuelLevel>
                <fuelFilter>
                    <thingDefs>
                        <li>Chemfuel</li>
                    </thingDefs>
                </fuelFilter>
                <fuelLabel>Chemfuel</fuelLabel>
                <fuelGizmoLabel>Chemfuel</fuelGizmoLabel>
                <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
                <autoRefuelPercent>1</autoRefuelPercent>
                <showFuelGizmo>true</showFuelGizmo>
                <drawOutOfFuelOverlay>false</drawOutOfFuelOverlay>
                <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
                <canEjectFuel>true</canEjectFuel>
            </li>
            <li Class="CompProperties_AmbientSound">
                <sound>ShuttleIdle_Ambience</sound>
            </li>
            <li Class="FCP.Core.Shuttles.CompProperties_AtmosphericOnly" />
        </comps>
        <placeWorkers>
            <li>PlaceWorker_NotUnderRoof</li>
        </placeWorkers>
        <uiOrder>2610</uiOrder>
    </ThingDef>

    <!-- FCP Light Vertibird (Fallout 4) -->

    <ThingDef ParentName="FCP_CraftableVertibirdBase" MayRequire="Ludeon.RimWorld.Odyssey">
        <defName>FCP_CraftableVertibird</defName>
        <label>light vertibird</label>
        <description>A pre-war military VTOL transport. The VB-01 was the workhorse of the US Armed Forces, serving in countless operations before the Great War. Its twin tiltrotor design allows vertical takeoff and high-speed forward flight through atmospheric conditions. The vertibird's turbine engines burn chemfuel efficiently but lack the power to reach orbit. What it loses in altitude, it makes up for in reliability and cargo space - these birds could haul a full squad anywhere on the continent.</description>
        <graphicData>
            <texPath>Things/Vehicles/FCP_Light_Vertibird_east</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>CutoutComplex</shaderType>
            <drawSize>(8,8)</drawSize>
            <shadowData>
                <volume>(4.1, 1.0, 1.8)</volume>
                <offset>(0, 0, -0.1)</offset>
            </shadowData>
        </graphicData>
        <comps>
            <li Class="CompProperties_Shuttle">
                <shipDef>Ship_CraftableVertibird</shipDef>
            </li>
            <li Class="CompProperties_Launchable">
                <fuelPerTile>2.0</fuelPerTile>
                <minFuelCost>40</minFuelCost>
                <skyfallerLeaving>FCP_CraftableVertibirdLeaving</skyfallerLeaving>
                <worldObjectDef>FCP_TravelingCraftableVertibird</worldObjectDef>
                <cooldownTicks>3750</cooldownTicks>
                <fixedLaunchDistanceMax>50</fixedLaunchDistanceMax>
                <cooldownEndedMessage>{0} is ready to launch again.</cooldownEndedMessage>
            </li>
            <li Class="FCP.Core.Shuttles.CompProperties_RotatingBlades">
                <bladeGraphicsData>
                    <li>
                        <bladeGraphic>
                            <texPath>Things/Vehicles/FCP_Vertibird_Light_Propeller</texPath>
                            <graphicClass>Graphic_Single</graphicClass>
                            <drawSize>(6,6)</drawSize>
                        </bladeGraphic>
                        <positionOffset>(1, 0, -2.5)</positionOffset>
                        <spinRate>1.5</spinRate>
                    </li>
                    <li>
                        <bladeGraphic>
                            <texPath>Things/Vehicles/FCP_Vertibird_Light_Propeller</texPath>
                            <graphicClass>Graphic_Single</graphicClass>
                            <drawSize>(6,6)</drawSize>
                        </bladeGraphic>
                        <positionOffset>(1, 0, 3.7)</positionOffset>
                        <spinRate>1.5</spinRate>
                    </li>
                </bladeGraphicsData>
            </li>
        </comps>
    </ThingDef>

