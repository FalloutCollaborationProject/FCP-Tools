    <!-- FCP Cargo Vertibird -->

    <ThingDef ParentName="FCP_CraftableVertibirdBase" MayRequire="Ludeon.RimWorld.Odyssey">
        <defName>FCP_CraftableVertibird_Cargo</defName>
