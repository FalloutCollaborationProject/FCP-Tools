<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--__________ Jobs __________-->

    <!-- Refuel Power Armor -->

    <JobDef>
        <defName>RR_RefuelPowerArmor</defName>
        <driverClass>FCP.Core.PowerArmor.JobDriver_RefuelPowerArmor</driverClass>
        <reportString>Refueling TargetA.</reportString>
        <allowOpportunisticPrefix>true</allowOpportunisticPrefix>
    </JobDef>

