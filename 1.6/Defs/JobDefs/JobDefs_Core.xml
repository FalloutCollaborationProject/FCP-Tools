        <defName>FCP_AICastAbilityAtTarget</defName>
        <driverClass>FCP.Core.JobDriver_AICastAbilityAtTarget</driverClass>
        <reportString>Casting ability at target.</reportString>
        <casualInterruptible>false</casualInterruptible>
        <collideWithPawns>true</collideWithPawns>
    </JobDef>

    <!-- Release Animal From Cage -->

    <JobDef>
        <defName>FCP_ReleaseAnimalFromCage</defName>
