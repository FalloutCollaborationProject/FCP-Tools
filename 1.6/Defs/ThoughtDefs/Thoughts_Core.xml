<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--__________ Thoughts __________-->

    <!--_____ Enlistment Thoughts _____-->

    <!-- Turned in an outlaw -->

    <ThoughtDef>
        <defName>FCP_NCR_Turned_In_An_Outlaw</defName>
        <durationDays>3</durationDays>
        <stackLimit>1</stackLimit>
        <stages>
            <li>
                <label>turned in an outlaw</label>
                <description>We apprehended a suspect and they're now being taken to the NCRCF.</description>
                <baseMoodEffect>2</baseMoodEffect>
            </li>
        </stages>
    </ThoughtDef>

    <!--_____ Food Thoughts _____-->

    <!-- Pre-War Food -->

    <ThoughtDef>
        <defName>FCP_Ate_Pre_War_Food</defName>
        <durationDays>1</durationDays>
        <stages>
            <li>
                <label>Ate Pre-War Food</label>
                <description>I ate some Pre-War food. Not too great, but better than raw food!</description>
                <baseMoodEffect>2</baseMoodEffect>
            </li>
        </stages>
        <replaceThoughts>
            <li>AteFineMeal</li>
            <li>AteLavishMeal</li>
        </replaceThoughts>
    </ThoughtDef>

    <!--_____ Stealthboy Thoughts _____-->

    <!-- Stealthboy Withdrawal -->

    <ThoughtDef>
        <defName>FCP_Thought_Stealthboy_Withdrawal</defName>
        <workerClass>ThoughtWorker_Hediff</workerClass>
        <hediff>FCP_Addiction_Stealthboy</hediff>
        <validWhileDespawned>true</validWhileDespawned>
        <developmentalStageFilter>Baby, Child, Adult</developmentalStageFilter>
        <stages>
            <li>
                <visible>false</visible>
            </li>
            <li>
                <label>stealthboy withdrawal</label>
                <description>I feel exposed without the stealth field. I need to disappear.</description>
                <baseMoodEffect>-15</baseMoodEffect>
            </li>
        </stages>
    </ThoughtDef>

</Defs>
