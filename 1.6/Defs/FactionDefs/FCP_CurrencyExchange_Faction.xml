<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<FactionDef>
		<defName>FCP_CurrencyExchange</defName>
		<label>currency exchanger</label>
		<description>Wandering currency traders who exchange bottle caps and other wasteland currencies.</description>
		<pawnSingular>trader</pawnSingular>
		<pawnsPlural>traders</pawnsPlural>
		<categoryTag>Misc</categoryTag>
		<settlementGenerationWeight>0</settlementGenerationWeight>
		<requiredCountAtGameStart>0</requiredCountAtGameStart>
		<canMakeRandomly>false</canMakeRandomly>
		<canStageAttacks>false</canStageAttacks>
		<hidden>true</hidden>
		<leaderTitle>exchanger</leaderTitle>
		<fixedLeaderKinds>
			<li>Empire_Common_Lodger</li>
		</fixedLeaderKinds>
		<factionIconPath>World/WorldObjects/DefaultSettlement</factionIconPath>
		<backstoryFilters>
			<li>
				<categories>
					<li>Offworld</li>
				</categories>
			</li>
		</backstoryFilters>
		<caravanTraderKinds>
			<li>FCP_CurrencyExchange_Trader</li>
		</caravanTraderKinds>
		<visitorTraderKinds>
			<li>FCP_CurrencyExchange_Trader</li>
		</visitorTraderKinds>
		<baseTraderKinds>
			<li>FCP_CurrencyExchange_Trader</li>
		</baseTraderKinds>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(0,35)</li>
				<li>(70,50)</li>
				<li>(700,100)</li>
				<li>(1300,150)</li>
				<li>(100000,10000)</li>
			</points>
		</maxPawnCostPerTotalPointsCurve>
		<pawnGroupMakers>
			<li>
				<kindDef>Trader</kindDef>
				<traders>
					<Empire_Common_Lodger>1</Empire_Common_Lodger>
				</traders>
				<carriers>
					<Muffalo>6</Muffalo>
				</carriers>
				<guards>
					<Empire_Fighter_Trooper>4</Empire_Fighter_Trooper>
				</guards>
			</li>
		</pawnGroupMakers>
		<maxConfigurableAtWorldCreation>9999</maxConfigurableAtWorldCreation>
		<permanentEnemy>false</permanentEnemy>
		<techLevel>Industrial</techLevel>
		<raidLootValueFromPointsCurve>
			<points>
				<li>(35,15)</li>
				<li>(100,120)</li>
				<li>(1000,500)</li>
				<li>(2000,800)</li>
				<li>(4000,1000)</li>
			</points>
		</raidLootValueFromPointsCurve>
		<modExtensions>
			<li Class="FCP.Currencies.CurrencyReplacement">
				<currency>FCP_Currency_Caps</currency>
			</li>
		</modExtensions>
	</FactionDef>

</Defs>
