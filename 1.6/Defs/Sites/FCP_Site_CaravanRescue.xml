<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--__________ Site Defs __________-->

    <!-- Site Caravan Rescue -->

    <SitePartDef>
        <defName>FCP_Site_CaravanRescue</defName>
        <label>ambushed caravan</label>
        <description>A trading caravan under attack by raiders.</description>
        <workerClass>SitePartWorker_Outpost</workerClass>
        <siteTexture>World/WorldObjects/DefaultSettlement</siteTexture>
        <expandingIconTexture>MapIcons/Sites/FCP_Caravan_Site</expandingIconTexture>
        <forceExitAndRemoveMapCountdownDurationDays>6</forceExitAndRemoveMapCountdownDurationDays>
        <requiresFaction>true</requiresFaction>
        <wantsThreatPoints>true</wantsThreatPoints>
        <tags>
            <li>FCP_Site_CaravanRescue</li>
        </tags>
    </SitePartDef>

    <GenStepDef>
        <defName>FCP_Site_CaravanRescue_Outpost</defName>
        <linkWithSite>FCP_Site_CaravanRescue</linkWithSite>
        <order>450</order>
        <genStep Class="GenStep_Outpost"/>
    </GenStepDef>

    <GenStepDef>
        <defName>FCP_Site_CaravanRescue_OutpostPower</defName>
        <linkWithSite>FCP_Site_CaravanRescue</linkWithSite>
        <order>451</order>
        <genStep Class="GenStep_Power"/>
    </GenStepDef>

