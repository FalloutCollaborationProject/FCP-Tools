<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <SitePartDef>
        <defName>FCP_Site_RadioactiveWasteDump</defName>
        <label>toxic waste dump</label>
        <description>A pre-war nuclear waste storage facility. The government buried tons of radioactive byproducts here before the bombs fell. Two centuries later, the containment is failing and deadly radiation seeps into the wasteland.</description>
        <workerClass>SitePartWorker</workerClass>
        <siteTexture>World/WorldObjects/Sites/GenericSite</siteTexture>
        <expandingIconTexture>MapIcons/Sites/FCP_Radiactive_Site</expandingIconTexture>
        <forceExitAndRemoveMapCountdownDurationDays>3</forceExitAndRemoveMapCountdownDurationDays>
        <tags>
            <li>FCP_Site_RadioactiveWasteDump</li>
        </tags>
    </SitePartDef>

    <GenStepDef>
        <defName>FCP_Site_RadioactiveWasteDump_Scatter</defName>
        <linkWithSite>FCP_Site_RadioactiveWasteDump</linkWithSite>
        <order>400</order>
        <genStep Class="GenStep_ScatterGroup">
            <minSpacing>8</minSpacing>
            <spotMustBeStandable>true</spotMustBeStandable>
            <allowRoofed>false</allowRoofed>
            <count>30</count>
            <groups>
                <li>
                    <things>
                        <FCP_RadioactiveWasteBarrel_Single>0.25</FCP_RadioactiveWasteBarrel_Single>
                        <FCP_RadioactiveWasteBarrel_Single_Exposed>0.25</FCP_RadioactiveWasteBarrel_Single_Exposed>
                        <FCP_RadioactiveWasteBarrel_Stack>0.2</FCP_RadioactiveWasteBarrel_Stack>
                        <FCP_RadioactiveWasteBarrel_Stack_Exposed>0.15</FCP_RadioactiveWasteBarrel_Stack_Exposed>
                        <FCP_RadioactiveWasteBarrel_Pallet>0.1</FCP_RadioactiveWasteBarrel_Pallet>
                        <FCP_RadioactiveWasteBarrel_Pallet_Exposed>0.05</FCP_RadioactiveWasteBarrel_Pallet_Exposed>
                    </things>
                </li>
            </groups>
        </genStep>
    </GenStepDef>

</Defs>
