<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--__________ Site Defs __________-->

    <!-- Site Supply Run -->

    <SitePartDef>
        <defName>FCP_Site_SupplyRun</defName>
        <label>supply cache</label>
        <description>A scavenging site with supplies to recover.</description>
        <workerClass>SitePartWorker_Outpost</workerClass>
        <siteTexture>World/WorldObjects/DefaultSettlement</siteTexture>
        <expandingIconTexture>MapIcons/Sites/FCP_Caravan_Site</expandingIconTexture>
        <forceExitAndRemoveMapCountdownDurationDays>6</forceExitAndRemoveMapCountdownDurationDays>
        <requiresFaction>true</requiresFaction>
        <wantsThreatPoints>true</wantsThreatPoints>
        <tags>
            <li>FCP_Site_SupplyRun</li>
        </tags>
    </SitePartDef>

    <GenStepDef>
        <defName>FCP_Site_SupplyRun_Outpost</defName>
        <linkWithSite>FCP_Site_SupplyRun</linkWithSite>
        <order>450</order>
        <genStep Class="GenStep_Outpost"/>
    </GenStepDef>

    <GenStepDef>
        <defName>FCP_Site_SupplyRun_OutpostPower</defName>
        <linkWithSite>FCP_Site_SupplyRun</linkWithSite>
        <order>451</order>
        <genStep Class="GenStep_Power"/>
    </GenStepDef>

</Defs>
