<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <!--__________ Wastelander Weapons __________-->

    <!-- FCP Base Without Recipe Maker - inherits from BaseGunWithQuality to avoid recipeMaker -->
    
    <ThingDef Name="FCP_Gun_NoRecipe_Base" Abstract="True" ParentName="BaseGunWithQuality">
        <weaponTags>
            <li>Gun</li>
        </weaponTags>
        <tradeTags>
            <li>WeaponRanged</li>
        </tradeTags>
        <comps>
            <li Class="CompProperties_Biocodable"/>
        </comps>
    </ThingDef>

    <!-- FCP Simple Weapon Makeable Base -->

    <ThingDef Name="FCP_Simple_Gun_Base" Abstract="True" ParentName="FCP_Gun_NoRecipe_Base">
        <techLevel>Industrial</techLevel>
        <smeltable>false</smeltable>
        <comps>
            <li Class="FCP.Core.WeaponCondition.CompProperties_WeaponCondition">
                <conditionLossPerShot>0.04</conditionLossPerShot>
                <jamThreshold>30</jamThreshold>
                <maxJamChance>0.20</maxJamChance>
                <spawnConditionMin>35</spawnConditionMin>
                <spawnConditionMax>80</spawnConditionMax>
            </li>
        </comps>
    </ThingDef>

    <ThingDef Name="FCP_Complex_Gun_Base" Abstract="True" ParentName="FCP_Gun_NoRecipe_Base">
        <techLevel>Industrial</techLevel>
        <smeltable>false</smeltable>
        <comps>
            <li Class="FCP.Core.WeaponCondition.CompProperties_WeaponCondition">
                <conditionLossPerShot>0.03</conditionLossPerShot>
                <jamThreshold>30</jamThreshold>
                <maxJamChance>0.15</maxJamChance>
                <spawnConditionMin>35</spawnConditionMin>
                <spawnConditionMax>90</spawnConditionMax>
            </li>
        </comps>
    </ThingDef>

    <ThingDef Name="FCP_Machining_Gun_Base" Abstract="True" ParentName="BaseHumanMakeableGun">
        <techLevel>Spacer</techLevel>
        <recipeMaker Inherit="false">
            <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
            <workSkill>Crafting</workSkill>
            <effectWorking>Smith</effectWorking>
            <soundWorking>Recipe_Machining</soundWorking>
            <recipeUsers>
                <li>FCP_Production_Fabrication_Workbench</li>
            </recipeUsers>
            <unfinishedThingDef>UnfinishedGun</unfinishedThingDef>
        </recipeMaker>
        <comps>
            <li Class="FCP.Core.WeaponCondition.CompProperties_WeaponCondition">
                <conditionLossPerShot>0.025</conditionLossPerShot>
                <jamThreshold>25</jamThreshold>
                <maxJamChance>0.10</maxJamChance>
                <spawnConditionMin>40</spawnConditionMin>
                <spawnConditionMax>100</spawnConditionMax>
            </li>
        </comps>
    </ThingDef>

    <ThingDef Name="FCP_Makeshift_Weapon_Base" Abstract="True" ParentName="BaseHumanMakeableGun">
        <techLevel>Medieval</techLevel>
        <recipeMaker Inherit="false">
            <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
            <workSkill>Crafting</workSkill>
            <effectWorking>Smith</effectWorking>
            <soundWorking>Recipe_Smith</soundWorking>
            <recipeUsers>
                <li></li>
            </recipeUsers>
            <unfinishedThingDef>UnfinishedGun</unfinishedThingDef>
        </recipeMaker>
        <comps>
            <li Class="FCP.Core.WeaponCondition.CompProperties_WeaponCondition">
                <conditionLossPerShot>0.06</conditionLossPerShot>
                <jamThreshold>40</jamThreshold>
                <maxJamChance>0.35</maxJamChance>
                <spawnConditionMin>45</spawnConditionMin>
                <spawnConditionMax>65</spawnConditionMax>
            </li>
        </comps>
    </ThingDef>
    
    <ThingDef Name="FCP_Melee_Blunt_Base" ParentName="BaseMeleeWeapon_Blunt_Quality" Abstract="true">
        <techLevel>Industrial</techLevel>
        <recipeMaker  Inherit="false">
            <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
            <workSkill>Crafting</workSkill>
            <effectWorking>Smith</effectWorking>
            <soundWorking>Recipe_Smith</soundWorking>
            <recipeUsers>
                <li>FCP_Production_Simple_Weapons_Workbench</li>
            </recipeUsers>
            <unfinishedThingDef>UnfinishedWeapon</unfinishedThingDef>
        </recipeMaker>
    </ThingDef>
    
    <ThingDef Name="FCP_Melee_Sharp_Base" ParentName="BaseMeleeWeapon_Sharp_Quality" Abstract="true">
        <techLevel>Industrial</techLevel>
        <recipeMaker  Inherit="false">
            <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
            <workSkill>Crafting</workSkill>
            <effectWorking>Smith</effectWorking>
            <soundWorking>Recipe_Smith</soundWorking>
            <recipeUsers>
                <li>FCP_Production_Simple_Weapons_Workbench</li>
            </recipeUsers>
            <unfinishedThingDef>UnfinishedWeapon</unfinishedThingDef>
        </recipeMaker>
    </ThingDef>
    
    <ThingDef Name="FCP_BaseGun" Abstract="True" ParentName="BaseGunWithQuality">
        <techLevel>Industrial</techLevel>
        <weaponTags>
            <li>Gun</li>
        </weaponTags>
        <tradeTags>
            <li>WeaponRanged</li>
        </tradeTags>
        <comps>
            <li Class="CompProperties_Biocodable"/>
            <li Class="FCP.Core.WeaponCondition.CompProperties_WeaponCondition">
                <conditionLossPerShot>0.03</conditionLossPerShot>
                <jamThreshold>30</jamThreshold>
                <maxJamChance>0.20</maxJamChance>
                <spawnConditionMin>35</spawnConditionMin>
                <spawnConditionMax>100</spawnConditionMax>
            </li>
        </comps>
    </ThingDef>
</Defs>