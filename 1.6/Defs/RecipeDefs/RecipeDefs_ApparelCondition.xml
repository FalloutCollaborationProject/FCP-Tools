<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!-- Repair Clothing -->

    <RecipeDef>
        <defName>FCP_Recipe_RepairClothing</defName>
        <label>repair clothing</label>
        <description>Patch and mend a damaged garment using cloth and thread, restoring it to full condition.</description>
        <workerClass>FCP.Core.WeaponCondition.RecipeWorker_RepairClothing</workerClass>
        <jobString>Repairing clothing.</jobString>
        <workAmount>2000</workAmount>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <workSkill>Crafting</workSkill>
        <workSkillLearnFactor>1</workSkillLearnFactor>
        <effectWorking>Tailor</effectWorking>
        <soundWorking>Recipe_Tailor</soundWorking>
        <ingredients>
            <li>
                <filter>
                    <categories>
                        <li>Textiles</li>
                    </categories>
                </filter>
                <count>15</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <categories>
                <li>Textiles</li>
            </categories>
        </fixedIngredientFilter>
        <recipeUsers>
            <li>FCP_Production_Tailoring_Workbench</li>
            <li>FCP_Production_Repair_Bench</li>
        </recipeUsers>
    </RecipeDef>

    <!-- Repair Armor -->

    <RecipeDef>
        <defName>FCP_Recipe_RepairArmor</defName>
        <label>repair armor</label>
        <description>Re-plate and reinforce a damaged set of armor using steel and spare components, restoring it to full condition.</description>
        <workerClass>FCP.Core.WeaponCondition.RecipeWorker_RepairArmor</workerClass>
        <jobString>Repairing armor.</jobString>
        <workAmount>3000</workAmount>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <workSkill>Crafting</workSkill>
        <workSkillLearnFactor>1</workSkillLearnFactor>
        <effectWorking>Smith</effectWorking>
        <soundWorking>Recipe_Smith</soundWorking>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Steel</li>
                    </thingDefs>
                </filter>
                <count>20</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>ComponentIndustrial</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Steel</li>
                <li>ComponentIndustrial</li>
            </thingDefs>
        </fixedIngredientFilter>
        <recipeUsers>
            <li>FCP_Production_Armor_Workbench</li>
            <li>FCP_Production_Repair_Bench</li>
        </recipeUsers>
    </RecipeDef>

</Defs>
