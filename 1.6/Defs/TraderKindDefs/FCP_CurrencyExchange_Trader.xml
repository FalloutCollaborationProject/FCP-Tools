<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<TraderKindDef>
		<defName>FCP_CurrencyExchange_Trader</defName>
		<label>currency exchanger</label>
		<commonality>1</commonality>
		<stockGenerators>
			<li Class="StockGenerator_SingleDef">
				<thingDef>FCP_Currency_Caps</thingDef>
				<countRange>5000~10000</countRange>
			</li>
			<li Class="StockGenerator_SingleDef" MayRequire="Rick.FCP.BOS">
				<thingDef>FCP_Currency_BoS_Scrip</thingDef>
				<countRange>4000~8000</countRange>
			</li>
			<li Class="StockGenerator_SingleDef" MayRequire="Rick.FCP.NCR">
				<thingDef>FCP_Currency_NCR_Dollar</thingDef>
				<countRange>12500~25000</countRange>
			</li>
			<li Class="StockGenerator_SingleDef" MayRequire="Rick.FCP.Legion">
				<thingDef>FCP_Currency_Legion_Denarius</thingDef>
				<countRange>1250~2500</countRange>
			</li>
			<li Class="StockGenerator_SingleDef" MayRequire="Rick.FCP.Enclave">
				<thingDef>FCP_Currency_Enclave_Platinum_Bullion</thingDef>
				<countRange>1428~2857</countRange>
			</li>
			<li Class="StockGenerator_SingleDef" MayRequire="Rick.FCP.PRC">
				<thingDef>FCP_Currency_PRC_Yuan</thingDef>
				<countRange>33333~66666</countRange>
			</li>
			<li Class="StockGenerator_SingleDef" MayRequire="Rick.FCP.UnitedStates">
				<thingDef>FCP_Currency_USA_Pre_War_Dollar</thingDef>
				<countRange>33333~66666</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>Silver</thingDef>
				<countRange>2500~5000</countRange>
			</li>
			<li Class="StockGenerator_SingleDef">
				<thingDef>Gold</thingDef>
				<countRange>500~1000</countRange>
			</li>
			<li Class="StockGenerator_BuySingleDef">
				<thingDef>FCP_Currency_Caps</thingDef>
			</li>
			<li Class="StockGenerator_BuySingleDef" MayRequire="Rick.FCP.BOS">
				<thingDef>FCP_Currency_BoS_Scrip</thingDef>
			</li>
			<li Class="StockGenerator_BuySingleDef" MayRequire="Rick.FCP.NCR">
				<thingDef>FCP_Currency_NCR_Dollar</thingDef>
			</li>
			<li Class="StockGenerator_BuySingleDef" MayRequire="Rick.FCP.Legion">
				<thingDef>FCP_Currency_Legion_Denarius</thingDef>
			</li>
			<li Class="StockGenerator_BuySingleDef" MayRequire="Rick.FCP.Enclave">
				<thingDef>FCP_Currency_Enclave_Platinum_Bullion</thingDef>
			</li>
			<li Class="StockGenerator_BuySingleDef" MayRequire="Rick.FCP.PRC">
				<thingDef>FCP_Currency_PRC_Yuan</thingDef>
			</li>
			<li Class="StockGenerator_BuySingleDef" MayRequire="Rick.FCP.UnitedStates">
				<thingDef>FCP_Currency_USA_Pre_War_Dollar</thingDef>
			</li>
			<li Class="StockGenerator_BuySingleDef">
				<thingDef>Silver</thingDef>
			</li>
			<li Class="StockGenerator_BuySingleDef">
				<thingDef>Gold</thingDef>
			</li>

		</stockGenerators>
		<modExtensions>
			<li Class="FCP.Currencies.CurrencyReplacement">
				<currency>FCP_Currency_Caps</currency>
			</li>
		</modExtensions>
	</TraderKindDef>

</Defs>
