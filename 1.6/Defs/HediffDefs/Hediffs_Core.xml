<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!--__________ Core Hediffs __________-->

    <!--_____ VATS Hediffs _____-->

    <!-- V.A.T.S. -->

    <HediffDef>
        <defName>FCP_VATS_VatsLink</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>V.A.T.S. Neural Link</label>
        <description>A neurally linked targeting computer which provides the pawn with the RimTech Assisisted Targeting System.</description>
        <defaultInstallPart>Head</defaultInstallPart>
        <comps>
            <li Class="HediffCompProperties_GiveAbility">
                <abilityDefs>
                    <li>FC_VATS_Attack</li>
                </abilityDefs>
            </li>
        </comps>
        <addedPartProps>
            <solid>true</solid>
        </addedPartProps>
    </HediffDef>

    <!--_____ Power Armor Hediffs _____-->

    <!-- Power Armor Empty Fuel -->

    <HediffDef ParentName="DiseaseBase">
        <defName>FCP_Hediff_Power_Armor_Empty_Fusion_Core</defName>
        <label>Power Armor (Empty Fusion Core)</label>
        <description>Your power armor is out of fusion cores!</description>
        <stages>
            <li>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <postFactor>-0.8</postFactor>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <postFactor>-0.5</postFactor>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

    <!--_____ Ghoul Hediffs _____-->

    <!-- Ghoul Toxic Heal -->

    <HediffDef>
        <defName>FCP_Hediff_ToxHeal</defName>
        <label>Sterilized</label>
        <description>placeholder.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(0.9, 1.0, 0.35)</defaultLabelColor>
        <initialSeverity>1</initialSeverity>
        <comps>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>7500~7500</disappearsAfterTicks>
            </li>
        </comps>
        <stages>
            <li>
                <statFactors>
                    <InjuryHealingFactor>1.5</InjuryHealingFactor>
                </statFactors>
            </li>
        </stages>
    </HediffDef>

    <!--_____ Crucifixion Hediffs _____-->

    <!-- Power Line Crucifixion -->

    <HediffDef>
        <defName>FCP_Crucified</defName>
        <label>Crucified</label>
        <description>This person is immobilized on a power line structure.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <initialSeverity>1</initialSeverity>
        <stages>
            <li>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <setMax>0</setMax>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <setMax>0</setMax>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

    <!-- Crucifixion Exhaustion -->

    <HediffDef>
        <defName>FCP_CrucifixionExhaustion</defName>
        <label>Crucifixion Exhaustion</label>
        <description>Extreme exhaustion from prolonged immobilization. Slowly reduces consciousness.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <initialSeverity>0.1</initialSeverity>
        <maxSeverity>1.0</maxSeverity>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>0.15</severityPerDay>
            </li>
        </comps>
        <stages>
            <li>
                <minSeverity>0</minSeverity>
                <label>early</label>
            </li>
            <li>
                <minSeverity>0.3</minSeverity>
                <label>moderate</label>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.10</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <minSeverity>0.6</minSeverity>
                <label>severe</label>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.25</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <minSeverity>0.9</minSeverity>
                <label>extreme</label>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.40</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

    <!-- Was Crucified -->

    <HediffDef>
        <defName>FCP_WasCrucified</defName>
        <label>Was Crucified</label>
        <description>This person was recently removed from crucifixion. They are weak and traumatized.</description>
        <hediffClass>HediffWithComps</hediffClass>
        <initialSeverity>1</initialSeverity>
        <comps>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>300000</disappearsAfterTicks>
            </li>
        </comps>
        <stages>
            <li>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <offset>-0.30</offset>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <offset>-0.20</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

    <!--_____ Stealthboy Hediffs _____-->

    <!-- Stealthboy 3001A field -->

    <HediffDef>
        <defName>FCP_Hediff_Stealthboy_3001A</defName>
        <label>Stealthboy Field (3001A)</label>
        <hediffClass>HediffWithComps</hediffClass>
        <description>A modulating stealth field bending light around the user.</description>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_Invisibility">
                <visibleToPlayer>true</visibleToPlayer>
            </li>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>600</disappearsAfterTicks>
                <showRemainingTime>True</showRemainingTime>
            </li>
            <li Class="HediffCompProperties_DisappearsOnDeath"/>
        </comps>
    </HediffDef>

    <!-- Stealthboy 3001B field -->

    <HediffDef>
        <defName>FCP_Hediff_Stealthboy_3001B</defName>
        <label>Stealthboy Field (3001B)</label>
        <hediffClass>HediffWithComps</hediffClass>
        <description>An improved modulating stealth field with extended duration.</description>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_Invisibility">
                <visibleToPlayer>true</visibleToPlayer>
            </li>
            <li Class="HediffCompProperties_Disappears">
                <disappearsAfterTicks>1200</disappearsAfterTicks>
                <showRemainingTime>True</showRemainingTime>
            </li>
            <li Class="HediffCompProperties_DisappearsOnDeath"/>
        </comps>
    </HediffDef>

    <!-- Tolerance -->

    <HediffDef ParentName="DrugToleranceBase">
        <defName>FCP_Tolerance_Stealthboy</defName>
        <label>Stealthboy Tolerance</label>
        <description>A built-up tolerance to stealthboy use. The more severe this tolerance is, the more stealthboy use it takes to get the same effect.</description>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-0.015</severityPerDay>
            </li>
            <li Class="HediffCompProperties_DrugEffectFactor">
                <chemical>FCP_Chemical_Stealthboy</chemical>
            </li>
        </comps>
    </HediffDef>

    <!-- Addiction -->

    <HediffDef ParentName="AddictionBase">
        <defName>FCP_Addiction_Stealthboy</defName>
        <label>Stealthboy Addiction</label>
        <description>A chemical addiction to stealthboy use. Long-term presence of the field has caused neurological adaptations at the cellular level, so the brain can no longer function properly without it.\n\nWithout regular stealthboy use, withdrawal symptoms will begin. However, extended abstinence will force the brain to adapt back to its normal state, resolving the addiction.</description>
        <hediffClass>Hediff_Addiction</hediffClass>
        <chemicalNeed>FCP_Chemical_Stealthboy</chemicalNeed>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-0.08</severityPerDay>
                <showDaysToRecover>true</showDaysToRecover>
            </li>
        </comps>
        <stages>
            <li>
            </li>
            <li>
                <label>withdrawal</label>
            </li>
        </stages>
    </HediffDef>

</Defs>
