<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <!-- US ARMY -->

    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Ideology</li>
        </mods>
        <match Class="PatchOperationAdd">
            <xpath>Defs/GenStepDef[defName="AncientJunkClusters"]/genStep/groups</xpath>
            <value>
                <li>
                    <things>
                        <FCP_Pre_War_Army_Vertibird>0.015</FCP_Pre_War_Army_Vertibird>
                        <FCP_Pre_War_Army_Truck>0.02</FCP_Pre_War_Army_Truck>
                    </things>
                    <indoorRuin>false</indoorRuin>
                    <coveredCellsPer10Cells>0.15~0.25</coveredCellsPer10Cells>
                    <filthDef>Filth_OilSmear</filthDef>
                    <filthExpandBy>1</filthExpandBy>
                    <filthChance>0.05</filthChance>
                    <clusterRectRadius>8~15</clusterRectRadius>
                </li>
                <li>
                    <things>
                        <FCP_Pre_War_Army_Truck>0.025</FCP_Pre_War_Army_Truck>
                    </things>
                    <indoorRuin>false</indoorRuin>
                    <coveredCellsPer10Cells>0.15~0.25</coveredCellsPer10Cells>
                    <filthDef>Filth_OilSmear</filthDef>
                    <filthExpandBy>1</filthExpandBy>
                    <filthChance>0.05</filthChance>
                    <clusterRectRadius>8~12</clusterRectRadius>
                </li>
                <li>
                    <things>
                        <FCP_Pre_War_Army_Vertibird>0.015</FCP_Pre_War_Army_Vertibird>
                    </things>
                    <indoorRuin>false</indoorRuin>
                    <coveredCellsPer10Cells>0.15~0.25</coveredCellsPer10Cells>
                    <filthDef>Filth_OilSmear</filthDef>
                    <filthExpandBy>1</filthExpandBy>
                    <filthChance>0.05</filthChance>
                    <clusterRectRadius>8~15</clusterRectRadius>
                </li>
            </value>
        </match>
    </Operation>

    <!-- Add Wall Terminal GenStep -->
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Ideology</li>
        </mods>
        <match Class="PatchOperationAdd">
            <xpath>Defs/MapGeneratorDef[@Name="MapCommonBase"]/genSteps</xpath>
            <value>
                <li MayRequire="Ludeon.RimWorld.Ideology">FCP_WallTerminals</li>
            </value>
        </match>
    </Operation>

</Patch>