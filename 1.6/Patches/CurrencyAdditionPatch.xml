<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Currency patch -->

	<!--
		- Automatically adds the mod extension to every faction that DOESN'T already have the mod extensions
		- If a faction already has the mod extension, they'll keep using whatever currency is already defined
		- HOWEVER make sure you use <modExtensions Inherit="False"> if inheriting from a non-abstract faction def, otherwise they will use the currency from that def instead
	-->

	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/FactionDef[not(modExtensions/li[@Class="FCP.Currencies.CurrencyReplacement"])]</xpath>
		<value>
			<li Class="FCP.Currencies.CurrencyReplacement">
				<currency>FCP_Currency_Caps</currency>
			</li>
		</value>
	</Operation>
	<Operation Class="PatchOperationAddModExtension">
		<xpath>Defs/TraderKindDef[orbital="true" and not(modExtensions/li[@Class="FCP.Currencies.CurrencyReplacement"])]</xpath>
		<value>
			<li Class="FCP.Currencies.CurrencyReplacement">
				<currency>FCP_Currency_Caps</currency>
			</li>
		</value>
	</Operation>
	
	<!-- Patch to replace scenarios that start with silver, to instead start with caps -->

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ScenarioDef/scenario/parts/li[thingDef="Silver"]/thingDef</xpath>
		<value>
			<thingDef>FCP_Currency_Caps</thingDef>
		</value>
	</Operation>

	<!-- Add a honor value to silver -->

	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[defName="Silver"]/statBases</xpath>
		<value>
			<RoyalFavorValue>0.0015</RoyalFavorValue>
		</value>
	</Operation>

	<!-- Caps drop for royal titles -->

	<Operation Class="PatchOperationSequence">
		<operations>
			<li Class="PatchOperationTest">
				<xpath>Defs/RoyalTitlePermitDef[defName="SilverDrop"]</xpath>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>Defs/RoyalTitlePermitDef[defName="SilverDrop"]/defName</xpath>
				<value><defName>CapsDrop</defName></value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>Defs/RoyalTitlePermitDef[defName="CapsDrop"]/label</xpath>
				<value><label>caps drop</label></value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>Defs/RoyalTitlePermitDef[defName="CapsDrop"]/description</xpath>
				<value><description>Call for a drop of 500 caps.</description></value>
			</li>
			<li Class="PatchOperationRemove">
				<xpath>Defs/RoyalTitlePermitDef[defName="CapsDrop"]/royalAid/itemsToDrop/Silver</xpath>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/RoyalTitlePermitDef[defName="CapsDrop"]/royalAid/itemsToDrop</xpath>
				<value><FCP_Currency_Caps>500</FCP_Currency_Caps></value>
			</li>
		</operations>
	</Operation>

	<!-- Tribute collector accepts caps -->

	<Operation Class="PatchOperationSequence">
		<operations>
			<li Class="PatchOperationTest">
				<xpath>Defs/TraderKindDef[defName="Empire_Caravan_TributeCollector"]</xpath>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/TraderKindDef[defName="Empire_Caravan_TributeCollector"]/stockGenerators</xpath>
				<value>
					<li Class="StockGenerator_BuySingleDef">
						<thingDef>FCP_Currency_Caps</thingDef>
					</li>
				</value>
			</li>
		</operations>
	</Operation>

</Patch>
